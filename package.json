{
  "name": "react-native-imei-serial-reader",
  "version": "0.1.0",
  "description": "Live-camera OCR scanner for IMEI / Serial Number / Flexible Barcode / Exact-Match readers. RN port of the Flutter imei_serial_reader package.",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "assets",
    "android",
    "ios",
    "patches",
    "react-native-imei-serial-reader.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "example": "yarn --cwd example"
  },
  "keywords": [
    "react-native",
    "imei",
    "serial",
    "ocr",
    "barcode",
    "vision-camera"
  ],
  "repository": "https://github.com/cashify/react-native-imei-serial-reader",
  "author": "Cashify",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.80.0",
    "react-native-vision-camera": "^4.7.0",
    "react-native-vision-camera-text-recognition": "^3.1.0",
    "react-native-worklets-core": ">=1.5.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.85.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prettier": "^3.2.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-vision-camera-text-recognition": "^3.1.1",
    "react-native-worklets-core": "^1.6.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "packageManager": "yarn@4.6.0+sha512.5383cc12567a95f1d668fbe762dfe0075c595b4bfff433be478dbbe24e05251a8e8c3eb992a986667c1d53b6c3a9c85b8398c35a960587fbd9fa3a0915406728"
}
